ADMIN_KEY=change-this-to-a-strong-random-string

# ── Storage ────────────────────────────────────────────────────────────────────
# "supabase" or "cloudinary"
STORAGE_PROVIDER=supabase

# Only needed if STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Geocoding ──────────────────────────────────────────────────────────────────
REVERSE_GEOCODER_PROVIDER=nominatim
NOMINATIM_USER_AGENT=nadibot/1.0

# ── Incident clustering ────────────────────────────────────────────────────────
DEFAULT_INCIDENT_RADIUS_METERS=500

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Audio ──────────────────────────────────────────────────────────────────────
# Files larger than this (bytes) get a placeholder transcript (Gemini Flash ~1 MB limit)
AUDIO_INLINE_MAX_BYTES=900000

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
API_BASE_URL=http://localhost:8000

# ── Telegram Webhook (set these for deployment; leave blank for local polling) ──
# Full public URL to /api/v1/telegram/webhook, e.g. https://your-app.onrender.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_URL=
# Random secret string; also passed to Telegram's setWebhook for validation
TELEGRAM_WEBHOOK_SECRET=
